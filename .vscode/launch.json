    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug stage extender",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "1",
                "bwf_results-historical_stage",
                "bwf_results-historical_stage"
            ]
        },
        {
            "name": "Run eval on historical stage",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle",
            "args": [
                "${workspaceFolder}/data/masterplan.json",
                "${workspaceFolder}/data/configuration.yaml"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Run configure on historical stage",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle.configure_system_cli",
            "args": [
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Current Test File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug eval on stage 1",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle",
            "args": [
                "${workspaceFolder}/teams/whale/1/bwf_inputs-whale-stage_1/masterplan.yaml",
                "${workspaceFolder}/teams/whale/1/bwf_inputs-whale-stage_1/configuration.yaml"
            ],
            "console": "integratedTerminal"
        }
    ]
}