{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug stage extender",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "1",
                "bwf_results-historical_stage",
                "bwf_results-historical_stage"
            ]
        },
        {
            "name": "Run eval on historical stage",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle",
            "args": [
                "${workspaceFolder}/data/masterplan.json",
                "${workspaceFolder}/data/configuration.yaml"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Run configure on historical stage",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle.configure_system_cli",
            "args": [
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Current Test File",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "${file}",
                "-v",
                "-s"
            ],
            "console": "integratedTerminal",
            "justMyCode": false
        },
        {
            "name": "Debug eval on stage 1",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle",
            "args": [
                "${workspaceFolder}/masterplans/masterplan-${input:masterplanFileName}.yaml",
                "${workspaceFolder}/teams/TEAM00/1/bwf_inputs-TEAM00-stage_1/configuration.yaml"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug submission",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle",
            "args": [
                "${env:HOME}/Documents/sandbox/${input:masterplanFileName}",
                "${env:HOME}/Documents/sandbox/bwf_inputs-test_stage_1/configuration.yaml"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "Debug submission evaluation",
            "type": "debugpy",
            "request": "launch",
            "module": "src.water_futures_battle",
            "args": [
                "${workspaceFolder}/teams/${input:teamName}/${input:stageNumber}/masterplan-${input:teamName}-stage_${input:stageNumber}.${input:masterplanExtension}",
                "${workspaceFolder}/teams/${input:teamName}/${input:stageNumber}/bwf_inputs-${input:teamName}-stage_${input:stageNumber}/configuration.yaml"
            ],
            "console": "integratedTerminal"
        },
    ],
    "inputs": [
        {
            "id": "masterplanFileName",
            "type": "promptString",
            "description": "Enter the name to the masterplan file",
            "default": "empty"
        },
        {
            "id": "teamName",
            "type": "promptString",
            "description": "Enter the team's name",
            "default": "TEAM00"
        },
        {
            "id": "stageNumber",
            "type": "promptString",
            "description": "Enter the stage number",
            "default": "1"
        },
        {
            "id": "masterplanExtension",
            "type": "promptString",
            "description": "Enter the masterplan's extenstion",
            "default": "yaml"
        }
    ]
}